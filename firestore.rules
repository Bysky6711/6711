rules_version = '2';

// Rules for the Mafia party game.
//
// The app signs every device in with Firebase Anonymous Auth (see main.dart),
// so we require an authenticated user for all room access. This blocks random,
// unauthenticated scanners/writers hitting the public deployment — anyone must
// at least hold a valid anonymous token from THIS app.
//
// NOTE: players are still identified by an in-app generated id (not the auth
// uid), so these rules intentionally do NOT lock individual fields to a
// specific host/player. To harden further you would store the host's auth uid
// on the room and gate status/phase transitions to it. For playing with friends
// the auth requirement below is the important step up from fully-open access.
//
// ⚠️ Requires "Anonymous" sign-in enabled: Firebase console → Build →
//    Authentication → Sign-in method → Anonymous → Enable.
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomCode} {
      allow read, write: if request.auth != null;

      // messages / actions / hands / votes / tasks / auction / state subcollections
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
